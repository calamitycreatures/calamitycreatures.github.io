---
import HeaderButton from '@components/HeaderButton.astro';

import LogoImage from '@assets/logo.png';
import {Image} from 'astro:assets';
---

<a href="/" class="text-center mb-6" style="z-index: 2; user-select: none;">
	<Image src={LogoImage}
    alt="Logo"
    class="max-w-full h-auto w-64 mx-auto"
    loading="eager"
    fetchpriority="high"
  />
</a>

<div class="-mt-8 w-auto bg-[#543b46] border-b-4 border-b-[#78565d] mb-16 rounded-2xl shadow-xl shadow-gray-950/40">
	<div class="max-w-6xl mx-auto px-4 flex flex-wrap justify-center gap-2 md:gap-4 py-3" style="user-select: none;">
      <HeaderButton title="Home" link="/"></HeaderButton>
      <HeaderButton title="Downloads" link="/downloads"></HeaderButton>
      <HeaderButton title="Credits" link="/credits"></HeaderButton>
      <HeaderButton title="Gallery" link="/wip"></HeaderButton>
	</div>
</div>