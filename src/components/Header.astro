---
import logoImage from '../assets/logo.png';
import { Image } from 'astro:assets';
---

<a href="/" class="text-center mb-6" style="z-index: 2">
	<Image src={logoImage}
    alt="Logo"
    class="max-w-full h-auto w-64 mx-auto"
    loading="eager"
    fetchpriority="high"
    />
</a>

<div class="-mt-8 w-auto bg-[#543b46] border-b-4 border-b-[#78565d] mb-16 rounded-2xl shadow-xl shadow-gray-950/40">
	<div class="max-w-6xl mx-auto px-4">
		<nav class="flex flex-wrap justify-center gap-2 md:gap-4 py-3">
			<a href="/" class="px-3 py-1 md:px-4 md:py-2 bg-[#78565d] hover:bg-[#8a656e] text-white font-medium rounded-md transition-colors">Home</a>
			<a href="/downloads" class="px-3 py-1 md:px-4 md:py-2 bg-[#78565d] hover:bg-[#8a656e] text-white font-medium rounded-md transition-colors">Downloads</a>
			<a href="/credits" class="px-3 py-1 md:px-4 md:py-2 bg-[#78565d] hover:bg-[#8a656e] text-white font-medium rounded-md transition-colors">Credits</a>
			<a href="wip" class="px-3 py-1 md:px-4 md:py-2 bg-[#78565d] hover:bg-[#8a656e] text-white font-medium rounded-md transition-colors">Gallery</a>
		</nav>
	</div>
</div>