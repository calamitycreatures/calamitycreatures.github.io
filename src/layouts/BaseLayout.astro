---
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

import {getImage} from 'astro:assets';

import {SITE} from '@config/SiteConfig.astro';

import '@styles/global.css';

interface Props {
  title?:string;
	icon?:ImageMetadata;
  description?:string;
  bgImage?:ImageMetadata;
  bannerImage?:ImageMetadata;
}

const {
	title = SITE.title,
	icon = SITE.icon,
	description = SITE.description,
  bgImage = SITE.bgImage,
  bannerImage = SITE.bannerImage
} = Astro.props;

const optimizedBackground = await getImage({src: bgImage, format: 'png'})
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8"/>
		<link rel="icon" type="image/png" href={icon.src}/>
		<meta name="viewport" content="width=device-width, initial-scale=1"/>
		<meta name="generator" content={Astro.generator}/>
		{description && <meta name="description" content={description}/>}
    <meta property="og:image" content={bannerImage.src}/>
    <meta name="twitter:image" content={bannerImage.src}/>
		<title>{`${title} - ${SITE.title}`}</title>
	</head>

	<body>
    <div style={`
      position: fixed;
      top: 0;
      left: 0;
      width: 110%;
      height: 110%;
      background: url(${optimizedBackground.src}) center/cover no-repeat;
      z-index: -1;
    `}></div>

		<div class="content-container">
			<Header/>
			<slot/>
			<Footer/>
		</div>
	</body>
</html>