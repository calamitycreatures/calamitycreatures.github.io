---
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

import {Image} from 'astro:assets';

import {SITE} from '@config/SiteConfig.astro';

import '@styles/global.css';

interface Props {
  title?:string;
	icon?:ImageMetadata;
  description?:string;
  bgImage?:ImageMetadata;
  bannerImage?:ImageMetadata;
}

const {
	title = SITE.title,
	icon = SITE.icon,
	description = SITE.description,
  bgImage = SITE.bgImage,
  bannerImage = SITE.bannerImage
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8"/>
		<link rel="icon" type="image/png" href={icon.src}/>
		<meta name="viewport" content="width=device-width, initial-scale=1"/>
		<meta name="generator" content={Astro.generator}/>
		{description && <meta name="description" content={description}/>}
    <meta property="og:image" content={bannerImage.src}/>
    <meta name="twitter:image" content={bannerImage.src}/>
		<title>{`${title} - ${SITE.title}`}</title>
	</head>

	<body>
		<Image 
			src={bgImage} 
			alt="Background" 
			aria-hidden="true"
			loading="eager"
			fetchpriority="high"
			style="position: fixed; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: -1; pointer-events: none; user-select: none;"
		/>

		<div class="content-container">
			<Header/>
			<slot/>
			<Footer/>
		</div>
	</body>
</html>